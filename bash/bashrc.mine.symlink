BASE_PATH=~/.dotfiles

for file in $BASE_PATH/*/*.src $BASE_PATH/*/*.bash
do
  [ -e "$file" ] && source $file
done

# Local private dotfiles

PRIVATE_DOTFILES_ROOT=~/.priv-dotfiles

if [ -e $PRIVATE_DOTFILES_ROOT ]
then
  for file in $(find -H "$PRIVATE_DOTFILES_ROOT" -maxdepth 2 \( -name '*.src' -o -name '*.bash' \))
  do
    source $file
  done

  pathappend $PRIVATE_DOTFILES_ROOT/bin
fi
